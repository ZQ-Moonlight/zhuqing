---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getReferenceGroups } from "../lib/contentArchive";
import { withBase } from "../lib/paths";

const reelDocs = (await getReferenceGroups()).find((group) => group.label === "reel")?.items ?? [];
---

<BaseLayout
    title="作品集 | 祝庆 Zhu Qing"
    description="祝庆的影视后期、UE5 交互、MetaHuman 与数字人工作流部分作品。"
    activePath="/portfolio"
    backgroundVariant="portfolio"
>
    <main class="page-shell portfolio-layout">
        <header class="portfolio-hero" data-reveal>
            <span class="eyebrow">作品 / 流程 / 后期</span>
            <h1>部分作品 Works</h1>
            <p>虚幻引擎交互、数字人技术研究、影视后期调色与电影放映。</p>
        </header>

        <section class="work-section" aria-labelledby="works-title">
            <div class="section-heading" data-reveal>
                <h2 id="works-title">部分项目</h2>
            </div>

            <div class="work-grid">
                <a href={withBase("/portfolio/detroit")} class="project-card" data-reveal>
                    <div class="card-image">
                        <img src={withBase("/images/portfolio/detroit/1.jpg")} alt="Detroit Become Human UE5 recreation" loading="lazy" />
                        <span class="card-hover">查看技术复盘</span>
                    </div>
                    <div class="card-info">
                        <span class="category">UE5 / 交互叙事</span>
                        <h3>《底特律：化身为人》场景与交互复刻</h3>
                        <p>章节级交互还原，包含蓝图 QTE、关卡序列、环境扫描、虚拟制片适配与镜头流程复盘。</p>
                    </div>
                </a>

                <a href={withBase("/portfolio/metahuman")} class="project-card" data-reveal>
                    <div class="card-image">
                        <img src={withBase("/images/portfolio/lightstage/lightstage-workflow-preview.jpg")} alt="MetaHuman and Light Stage workflow" loading="lazy" />
                        <span class="card-hover">查看数字人流程</span>
                    </div>
                    <div class="card-info">
                        <span class="category">数字人 / 工作流</span>
                        <h3>MetaHuman 与数字人光场流程</h3>
                        <p>研究数字人资产规范、表情/材质流程与高精度光照采集，探索实时数字人的视觉可信度边界。</p>
                    </div>
                </a>

                <a href={withBase("/portfolio/guangying-changqing")} class="project-card" data-reveal>
                    <div class="card-image">
                        <img src={withBase("/images/portfolio/changqing/still.png")} alt="Light and Shadow Changqing digital image work" loading="lazy" />
                        <span class="card-hover">查看项目复盘</span>
                    </div>
                    <div class="card-info">
                        <span class="category">数字人 / 高斯泼溅 / 叙事短片</span>
                        <h3>《光影长青》</h3>
                        <p>结合 MetaHuman 数字人、高斯泼溅校园场景重建与人文叙事，完成一段跨越时空的影像对话。</p>
                    </div>
                </a>

                <article class="project-card" data-reveal>
                    <div class="card-image">
                        <img src={withBase("/images/portfolio/post/dcp-screening.jpg")} alt="DCP screening on Barco projector" loading="lazy" />
                    </div>
                    <div class="card-info">
                        <span class="category">DCP / 电影节字幕</span>
                        <h3>电影节 DCP 与外挂字幕放映</h3>
                        <p>这张图拍自C329教室，使用系里的 Barco 投影机完成 DCP 放映测试，并制作日语竖排加 ruby 注音的外挂字幕，字幕以外挂形式展示，不烧入画面。</p>
                    </div>
                </article>

                <article class="project-card" data-reveal>
                    <div class="card-image">
                        <img src={withBase("/images/portfolio/ndisplay/ndisplay-wall-01-preview.jpg")} alt="Post-production and color grading work" loading="lazy" />
                    </div>
                    <div class="card-info">
                        <span class="category">后期 / 剪辑 / 调色</span>
                        <h3>商业与品牌后期合作</h3>
                        <p>参与短片剪辑、调色和影像包装，熟练使用 DaVinci Resolve。合作对象包括小红书、国家地理等品牌内容。</p>
                    </div>
                </article>
            </div>
        </section>

        <section class="work-section reel-hub" aria-labelledby="reel-hub-title">
            <div class="section-heading" data-reveal>
                <h2 id="reel-hub-title">Reel</h2>
            </div>

            <div class="reel-placeholder" data-reveal>
                <span class="category">Showreel / Coming Soon</span>
                <strong>Reel 链接整理中</strong>
                <p>这里会单独放置可播放的 showreel 与阶段性影像合集，后续补充链接后可以直接更新这个区块。</p>
            </div>
        </section>

        {reelDocs.length > 0 && (
            <section class="work-section reel-section" aria-labelledby="reel-title">
                <div class="section-heading" data-reveal>
                    <h2 id="reel-title">资料下载</h2>
                </div>

                <div class="reel-list">
                    {reelDocs.map((item) => (
                        <a class="reel-item" href={item.href} target="_blank" rel="noreferrer" data-reveal>
                            <span class="file-chip">{item.kind}</span>
                            <span class="reel-item__main">
                                <strong>{item.title}</strong>
                                {item.description && <small>{item.description}</small>}
                                <span class="reel-meta">
                                    <time>上传 {item.uploadedLabel}</time>
                                    <span>{item.sizeLabel}</span>
                                </span>
                                <span class="reel-tags">
                                    {item.tags.map((tag) => <em>{tag}</em>)}
                                </span>
                            </span>
                        </a>
                    ))}
                </div>
            </section>
        )}
    </main>

    <footer class="site-footer">© 2026 祝庆 Zhu Qing</footer>
</BaseLayout>

<style>
    .portfolio-layout {
        max-width: 1420px;
    }

    .portfolio-hero {
        width: min(820px, 100%);
        margin-bottom: 72px;
    }

    .portfolio-hero h1 {
        margin: 12px 0 18px;
        color: var(--text-main);
        font-family: var(--font-display);
        font-size: var(--title-page);
        line-height: 1;
        letter-spacing: 0;
        text-wrap: balance;
    }

    .portfolio-hero p {
        margin: 0;
        color: var(--text-muted);
        font-size: var(--text-lead);
        line-height: 1.78;
    }

    .work-section {
        margin-bottom: 96px;
    }

    .reel-section {
        margin-top: 22px;
    }

    .work-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: clamp(28px, 4vw, 44px);
    }

    .project-card {
        display: block;
        color: inherit;
        text-decoration: none;
    }

    .card-image {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        margin-bottom: 20px;
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #111;
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(0.72) saturate(0.82);
        transition: transform 640ms cubic-bezier(0.2, 0.8, 0.2, 1), filter 260ms ease;
    }

    .project-card:hover img {
        transform: scale(1.045);
        filter: brightness(0.92) saturate(0.92);
    }

    .card-hover {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        color: #fff;
        font-weight: 700;
        background: rgba(0, 0, 0, 0.64);
        opacity: 0;
        transition: opacity 220ms ease;
    }

    .project-card:hover .card-hover {
        opacity: 1;
    }

    .category {
        display: block;
        margin-bottom: 8px;
        color: var(--accent);
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 760;
        letter-spacing: var(--tracking-kicker);
        text-transform: uppercase;
    }

    .card-info h3 {
        margin: 0 0 10px;
        color: var(--text-main);
        font-family: var(--font-display);
        font-size: var(--title-card);
        line-height: 1.32;
    }

    .card-info p {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.7;
    }

    .reel-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: clamp(18px, 3vw, 28px);
    }

    .reel-placeholder {
        display: grid;
        gap: 8px;
        max-width: 680px;
        border-left: 2px solid rgba(255, 94, 0, 0.58);
        background: linear-gradient(90deg, rgba(255, 94, 0, 0.06), transparent);
        padding: 18px 0 18px 22px;
    }

    .reel-placeholder strong {
        color: var(--text-main);
        font-family: var(--font-display);
        font-size: var(--title-card);
    }

    .reel-placeholder p {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.7;
    }

    .reel-item {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 18px;
        align-items: start;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--bg-panel);
        color: inherit;
        padding: 20px;
        text-decoration: none;
        transition: border-color 180ms ease, background 180ms ease, transform 180ms ease;
    }

    .reel-item:hover {
        border-color: rgba(255, 94, 0, 0.42);
        background: var(--bg-panel-strong);
        transform: translateY(-2px);
    }

    .reel-item__main {
        display: grid;
        gap: 8px;
        min-width: 0;
    }

    .reel-item strong {
        color: var(--text-main);
        font-size: 1.04rem;
        line-height: 1.35;
    }

    .reel-item small,
    .reel-meta {
        color: var(--text-muted);
        font-size: 0.84rem;
        line-height: 1.58;
    }

    .reel-meta,
    .reel-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .reel-tags em {
        border: 1px solid var(--border);
        border-radius: 999px;
        color: var(--text-muted);
        font-size: 0.72rem;
        font-style: normal;
        line-height: 1;
        padding: 4px 8px;
    }

    .file-chip {
        border-radius: 4px;
        background: var(--accent);
        color: #fff;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        padding: 5px 9px;
    }

    @media (max-width: 900px) {
        .work-grid,
        .reel-list {
            grid-template-columns: 1fr;
        }
    }
</style>
