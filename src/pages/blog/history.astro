---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/paths";

const archiveUrl = "https://ZQ-Moonlight.github.io/history-archive/";
const localArchiveUrl = "http://127.0.0.1:4323/history-archive/";
---

<BaseLayout
    title="历史资料入口 | Archive | 祝庆 Zhu Qing"
    description="中国近现代史与文革资料分析文章的独立站点入口。"
    activePath="/blog"
    backgroundVariant="article"
    noindex
>
    <main class="page-shell history-entry-page">
        <section class="history-entry" data-reveal>
            <span class="history-entry__star" aria-hidden="true">★</span>
            <span class="eyebrow">历史资料入口 / External Dossier</span>
            <h1>四海翻腾云水怒，狂飙骤息是何年？</h1>
            <p>
                输入原访问密码后，会跳转到独立的中国近现代史与文革资料分析站点。
            </p>

            <form
                class="history-entry__form"
                data-history-entry-form
                data-archive-url={archiveUrl}
                data-local-archive-url={localArchiveUrl}
                novalidate
            >
                <label class="sr-only" for="history-password">访问密码</label>
                <input
                    id="history-password"
                    data-history-password
                    name="password"
                    type="password"
                    inputmode="numeric"
                    autocomplete="off"
                    placeholder="输入年份"
                    aria-describedby="history-entry-message"
                />
                <button type="submit">进入站点</button>
            </form>
            <p class="history-entry__message" id="history-entry-message" data-history-entry-message aria-live="polite"></p>

            <a class="history-entry__back" href={withBase("/blog")}>返回 Archive</a>
        </section>
    </main>

    <footer class="site-footer">© 2026 祝庆 Zhu Qing</footer>

    <script is:inline>
        const form = document.querySelector("[data-history-entry-form]");
        const input = document.querySelector("[data-history-password]");
        const message = document.querySelector("[data-history-entry-message]");
        const correctPassword = "1976";

        const getArchiveUrl = () => {
            const remote = form?.getAttribute("data-archive-url") ?? "/";
            const local = form?.getAttribute("data-local-archive-url") ?? remote;
            const isLocalHost = ["localhost", "127.0.0.1", "::1"].includes(window.location.hostname);
            return isLocalHost ? local : remote;
        };

        input?.focus({ preventScroll: true });

        form?.addEventListener("submit", (event) => {
            event.preventDefault();

            if (input?.value.trim() === correctPassword) {
                if (message) message.textContent = "权限确认，正在切换到独立资料站。";
                window.setTimeout(() => {
                    window.location.href = getArchiveUrl();
                }, 280);
                return;
            }

            if (message) message.textContent = "抱歉，或许在历史的洪流中，我们暂时无法同频共振。";
            if (input) {
                input.value = "";
                input.classList.remove("is-shaking");
                void input.offsetWidth;
                input.classList.add("is-shaking");
                input.focus();
            }
        });

        input?.addEventListener("animationend", () => {
            input.classList.remove("is-shaking");
        });
    </script>
</BaseLayout>

<style>
    .history-entry-page {
        min-height: calc(100vh - var(--header-height));
        display: grid;
        place-items: center;
    }

    .history-entry {
        position: relative;
        overflow: hidden;
        width: min(100%, 680px);
        padding: clamp(28px, 5vw, 54px);
        border: 1px solid rgba(210, 28, 28, 0.5);
        border-radius: 8px;
        background:
            radial-gradient(circle at 87% 14%, rgba(255, 55, 55, 0.3), transparent 15rem),
            linear-gradient(135deg, rgba(92, 7, 7, 0.96), rgba(13, 8, 8, 0.96) 52%, rgba(9, 9, 10, 0.96)),
            var(--bg-panel);
        box-shadow: 0 28px 80px rgba(0, 0, 0, 0.46), 0 0 0 1px rgba(255, 205, 151, 0.04) inset;
    }

    .history-entry::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
            linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px),
            linear-gradient(0deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
        background-size: 42px 42px;
        mask-image: linear-gradient(135deg, transparent, #000 18%, transparent 76%);
        opacity: 0.28;
    }

    .history-entry__star {
        position: absolute;
        top: -24px;
        right: clamp(20px, 6vw, 46px);
        color: rgba(255, 48, 48, 0.78);
        font-size: clamp(7rem, 20vw, 12rem);
        line-height: 1;
        text-shadow: 0 0 36px rgba(255, 0, 0, 0.22);
        transform: rotate(-9deg);
    }

    .history-entry > *:not(.history-entry__star) {
        position: relative;
        z-index: 1;
    }

    .history-entry h1 {
        margin: 14px 0 18px;
        color: var(--text-main);
        font-family: var(--font-display);
        font-size: clamp(2rem, 4.6vw, 3.8rem);
        line-height: 1.22;
        letter-spacing: 0;
        text-wrap: balance;
    }

    .history-entry p {
        margin: 0;
        color: var(--text-muted);
        font-size: var(--text-lead);
        line-height: 1.78;
    }

    .history-entry__form {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 10px;
        margin-top: 34px;
    }

    .history-entry input,
    .history-entry button {
        min-height: 48px;
        border-radius: 4px;
        font: inherit;
    }

    .history-entry input {
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.16);
        outline: none;
        background: rgba(0, 0, 0, 0.3);
        color: #fff;
        padding: 0 14px;
    }

    .history-entry input:focus {
        border-color: rgba(255, 94, 0, 0.62);
    }

    .history-entry button {
        border: 1px solid rgba(255, 94, 0, 0.72);
        background: rgba(255, 94, 0, 0.14);
        color: #fff;
        cursor: pointer;
        font-weight: 760;
        padding: 0 18px;
        transition: background 180ms ease, border-color 180ms ease;
    }

    .history-entry button:hover {
        background: rgba(255, 94, 0, 0.24);
        border-color: rgba(255, 94, 0, 0.9);
    }

    .history-entry__message {
        min-height: 1.5em;
        margin-top: 12px;
        color: #ffb0a3;
        font-size: 0.92rem;
    }

    .history-entry__back {
        display: inline-flex;
        width: fit-content;
        margin-top: 18px;
        color: var(--text-dim);
        font-size: 0.88rem;
        text-decoration: none;
        transition: color 180ms ease;
    }

    .history-entry__back:hover {
        color: var(--text-main);
    }

    .history-entry input.is-shaking {
        border-color: rgba(255, 102, 102, 0.82);
        animation: entryShake 420ms cubic-bezier(0.36, 0.07, 0.19, 0.97);
    }

    :root[data-theme="light"] .history-entry input {
        border-color: rgba(20, 20, 20, 0.16);
        background: rgba(255, 255, 255, 0.72);
        color: var(--text-main);
    }

    :root[data-theme="light"] .history-entry button {
        background: rgba(200, 79, 18, 0.08);
        color: var(--accent);
    }

    :root[data-theme="light"] .history-entry button:hover {
        background: rgba(200, 79, 18, 0.14);
    }

    :root[data-theme="light"] .history-entry__message {
        color: var(--danger);
    }

    @keyframes entryShake {
        10%,
        90% {
            transform: translateX(-1px);
        }
        20%,
        80% {
            transform: translateX(2px);
        }
        30%,
        50%,
        70% {
            transform: translateX(-4px);
        }
        40%,
        60% {
            transform: translateX(4px);
        }
    }

    @media (max-width: 560px) {
        .history-entry__form {
            grid-template-columns: 1fr;
        }

        .history-entry button {
            width: 100%;
        }
    }
</style>
