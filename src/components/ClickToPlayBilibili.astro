---
interface Props {
    bvid: string;
    title: string;
    poster?: string;
    eyebrow?: string;
    heading?: string;
    description?: string;
    compact?: boolean;
}

const {
    bvid,
    title,
    poster = "/images/portfolio/detroit/1.jpg",
    eyebrow,
    heading,
    description,
    compact = false,
} = Astro.props;

const playerSrc = `https://player.bilibili.com/player.html?bvid=${bvid}&page=1&high_quality=1&danmaku=0&autoplay=1`;
---

<div
    class:list={["bilibili-click-player", compact && "bilibili-click-player--compact"]}
    data-bilibili-player
    data-src={playerSrc}
    data-title={title}
>
    <button class="bilibili-click-player__poster" type="button" aria-label={`播放 ${title}`}>
        <img src={poster} alt="" loading="lazy" />
        <span class="bilibili-click-player__shade"></span>
        <span class="bilibili-click-player__content">
            {eyebrow && <span class="eyebrow">{eyebrow}</span>}
            {heading && <strong>{heading}</strong>}
            {description && <small>{description}</small>}
            <span class="bilibili-click-player__play" aria-hidden="true">
                <span></span>
            </span>
        </span>
    </button>
</div>

<script is:inline>
    if (!window.__bilibiliClickPlayersInitialized) {
        window.__bilibiliClickPlayersInitialized = true;

        document.addEventListener("click", (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;

            const button = target.closest("[data-bilibili-player] button");
            if (!button) return;

            const player = button.closest("[data-bilibili-player]");
            if (!player || player.querySelector("iframe")) return;

            const iframe = document.createElement("iframe");
            iframe.src = player.dataset.src;
            iframe.title = player.dataset.title || "Bilibili video";
            iframe.loading = "lazy";
            iframe.scrolling = "no";
            iframe.allowFullscreen = true;
            iframe.allow = "fullscreen; autoplay";
            player.append(iframe);
            button.setAttribute("hidden", "");
        });
    }
</script>

<style>
    .bilibili-click-player,
    .bilibili-click-player__poster,
    .bilibili-click-player iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .bilibili-click-player__poster {
        display: block;
        border: 0;
        padding: 0;
        overflow: hidden;
        background: #111;
        color: inherit;
        cursor: pointer;
        font: inherit;
        text-align: left;
    }

    .bilibili-click-player__poster img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(0.58) saturate(0.82);
        transform: scale(1.01);
        transition: transform 520ms ease, filter 240ms ease;
    }

    .bilibili-click-player__poster:hover img {
        transform: scale(1.045);
        filter: brightness(0.72) saturate(0.9);
    }

    .bilibili-click-player__shade {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(0, 0, 0, 0.82), rgba(0, 0, 0, 0.34) 46%, rgba(0, 0, 0, 0.1));
    }

    .bilibili-click-player__content {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 10px;
        padding: clamp(24px, 5vw, 64px);
    }

    .bilibili-click-player__content strong {
        color: #fff;
        font-size: clamp(2.5rem, 7vw, 5.4rem);
        font-weight: 780;
        line-height: 0.95;
        text-transform: uppercase;
    }

    .bilibili-click-player__content small {
        max-width: 540px;
        color: var(--text-muted);
        font-size: clamp(0.95rem, 1.6vw, 1.15rem);
        line-height: 1.6;
    }

    .bilibili-click-player__play {
        display: grid;
        place-items: center;
        width: 56px;
        height: 56px;
        margin-top: 10px;
        border: 1px solid rgba(255, 255, 255, 0.34);
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(12px);
    }

    .bilibili-click-player__play span {
        width: 0;
        height: 0;
        margin-left: 4px;
        border-top: 10px solid transparent;
        border-bottom: 10px solid transparent;
        border-left: 15px solid #fff;
    }

    .bilibili-click-player iframe {
        border: 0;
    }

    .bilibili-click-player--compact .bilibili-click-player__shade {
        background: rgba(0, 0, 0, 0.42);
    }

    .bilibili-click-player--compact .bilibili-click-player__content {
        align-items: center;
        padding: 20px;
        text-align: center;
    }

    .bilibili-click-player--compact .bilibili-click-player__content strong {
        font-size: clamp(1rem, 2vw, 1.25rem);
        line-height: 1.25;
        text-transform: none;
    }

    .bilibili-click-player--compact .bilibili-click-player__content small,
    .bilibili-click-player--compact .eyebrow {
        display: none;
    }

    .bilibili-click-player--compact .bilibili-click-player__play {
        width: 46px;
        height: 46px;
        margin-top: 0;
    }

    @media (max-width: 720px) {
        .bilibili-click-player__shade {
            background: linear-gradient(0deg, rgba(0, 0, 0, 0.88), rgba(0, 0, 0, 0.14));
        }

        .bilibili-click-player__content {
            justify-content: flex-end;
        }
    }
</style>
