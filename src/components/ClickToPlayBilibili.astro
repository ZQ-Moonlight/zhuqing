---
interface Props {
    bvid: string;
    title: string;
    poster?: string;
    eyebrow?: string;
    heading?: string;
    description?: string;
    compact?: boolean;
}

const { bvid, title, compact = false } = Astro.props;

const playerParams = new URLSearchParams({
    bvid,
    page: "1",
    p: "1",
    as_wide: "1",
    high_quality: "1",
    danmaku: "0",
    autoplay: "0",
});
const playerSrc = `https://player.bilibili.com/player.html?${playerParams.toString()}`;
const videoUrl = `https://www.bilibili.com/video/${bvid}/`;
---

<div class:list={["bilibili-embed-player", compact && "bilibili-embed-player--compact"]}>
    <iframe
        src={playerSrc}
        title={title}
        loading="eager"
        scrolling="no"
        frameborder="0"
        allow="fullscreen; autoplay; picture-in-picture"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
    ></iframe>
    <a class="bilibili-embed-player__fallback" href={videoUrl} target="_blank" rel="noreferrer">
        &#22312; Bilibili &#25171;&#24320;
    </a>
</div>

<style>
    .bilibili-embed-player,
    .bilibili-embed-player iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .bilibili-embed-player {
        overflow: hidden;
        background: #050505;
        isolation: isolate;
    }

    .bilibili-embed-player iframe {
        display: block;
        border: 0;
        background: #050505;
        color-scheme: dark;
    }

    .bilibili-embed-player__fallback {
        position: absolute;
        right: 12px;
        bottom: 12px;
        z-index: 2;
        border: 1px solid rgba(255, 255, 255, 0.22);
        border-radius: 999px;
        background: rgba(5, 5, 5, 0.72);
        color: #fff;
        font-family: var(--font-mono);
        font-size: 0.76rem;
        line-height: 1;
        padding: 8px 11px;
        text-decoration: none;
        transition: border-color 180ms ease, background 180ms ease;
    }

    .bilibili-embed-player__fallback:hover {
        border-color: rgba(255, 94, 0, 0.58);
        background: rgba(255, 94, 0, 0.86);
    }

    .bilibili-embed-player--compact .bilibili-embed-player__fallback {
        display: none;
    }
</style>
