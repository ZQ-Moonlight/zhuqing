---
import AmbientBackground from "../components/AmbientBackground.astro";
import FilmGrain from "../components/FilmGrain.astro";
import Header from "../components/Header.astro";
import { withBase } from "../lib/paths";

interface Props {
    title?: string;
    description?: string;
    image?: string;
    activePath?: string;
    backgroundVariant?: "default" | "portfolio" | "article";
    noindex?: boolean;
}

const {
    title = "祝庆 Zhu Qing | 影视后期与 Unreal Engine 开发",
    description = "祝庆的个人作品集与博客，聚焦影视后期、Unreal Engine、虚拟制片、MetaHuman 与视觉设计。",
    image = "/images/home/zq.jpg",
    activePath = Astro.url.pathname,
    backgroundVariant = "default",
    noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const imagePath = withBase(image);
const absoluteImage = new URL(imagePath, Astro.url.origin).toString();
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonical} />
        {noindex && <meta name="robots" content="noindex, nofollow" />}
        <meta name="theme-color" content="#050505" />
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={absoluteImage} />
        <meta property="og:url" content={canonical} />
        <meta name="twitter:card" content="summary_large_image" />
        <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
        <link rel="icon" href={withBase("/favicon.ico")} />
        <script is:inline>
            document.documentElement.classList.add("js");
            try {
                const savedTheme = localStorage.getItem("zq-theme");
                document.documentElement.dataset.theme = savedTheme || "dark";
            } catch {
                document.documentElement.dataset.theme = "dark";
            }
        </script>
    </head>
    <body>
        <div class="read-progress" data-read-progress aria-hidden="true"></div>
        <FilmGrain />
        <AmbientBackground variant={backgroundVariant} />
        <Header activePath={activePath} />
        <div class="theme-tip" data-theme-tip hidden>
            <span>最佳视觉效果建议使用暗黑模式。</span>
            <button type="button" data-theme-tip-close aria-label="关闭暗黑模式提示">×</button>
        </div>
        <slot />

        <script is:inline>
            const header = document.querySelector("[data-site-header]");
            const progress = document.querySelector("[data-read-progress]");
            const revealItems = document.querySelectorAll("[data-reveal]");
            const themeToggle = document.querySelector("[data-theme-toggle]");
            const themeToggleLabel = document.querySelector("[data-theme-toggle-label]");
            const themeTip = document.querySelector("[data-theme-tip]");
            const themeTipClose = document.querySelector("[data-theme-tip-close]");
            const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
            let themeTipTimer;

            const syncThemeLabel = () => {
                const isLight = document.documentElement.dataset.theme === "light";
                const label = isLight ? "切换为黑暗风格" : "切换为明亮风格";
                if (themeToggleLabel) themeToggleLabel.textContent = label;
                themeToggle?.setAttribute("aria-label", label);
                themeToggle?.setAttribute("title", label);
                themeToggle?.setAttribute("aria-pressed", String(isLight));
            };

            const hideThemeTip = () => {
                window.clearTimeout(themeTipTimer);
                themeTip?.setAttribute("hidden", "");
            };

            const showThemeTip = () => {
                if (document.documentElement.dataset.theme !== "light") return;
                themeTip?.removeAttribute("hidden");
                window.clearTimeout(themeTipTimer);
                themeTipTimer = window.setTimeout(hideThemeTip, 5200);
            };

            syncThemeLabel();
            try {
                if (document.documentElement.dataset.theme === "light" && sessionStorage.getItem("zq-theme-tip-seen") !== "1") {
                    sessionStorage.setItem("zq-theme-tip-seen", "1");
                    showThemeTip();
                }
            } catch {
                showThemeTip();
            }

            themeToggle?.addEventListener("click", () => {
                const nextTheme = document.documentElement.dataset.theme === "light" ? "dark" : "light";
                document.documentElement.dataset.theme = nextTheme;
                try {
                    localStorage.setItem("zq-theme", nextTheme);
                } catch {}
                syncThemeLabel();
                if (nextTheme === "light") {
                    showThemeTip();
                } else {
                    hideThemeTip();
                }
            });
            themeTipClose?.addEventListener("click", hideThemeTip);

            const updateChrome = () => {
                const scrollTop = window.scrollY || document.documentElement.scrollTop;
                header?.classList.toggle("is-scrolled", scrollTop > 12);

                if (progress) {
                    const doc = document.documentElement;
                    const maxScroll = Math.max(1, doc.scrollHeight - doc.clientHeight);
                    progress.style.transform = `scaleX(${Math.min(1, scrollTop / maxScroll)})`;
                }
            };

            updateChrome();
            window.addEventListener("scroll", updateChrome, { passive: true });

            if (reducedMotion) {
                revealItems.forEach((item) => item.classList.add("is-visible"));
            } else {
                const observer = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                entry.target.classList.add("is-visible");
                                observer.unobserve(entry.target);
                            }
                        });
                    },
                    { threshold: 0.18, rootMargin: "0px 0px -8% 0px" }
                );

                revealItems.forEach((item) => observer.observe(item));
            }
        </script>
    </body>
</html>

<style is:global>
    @import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;520;600;700;800&family=Noto+Sans+SC:wght@300;400;500;700&family=Noto+Serif+SC:wght@500;600;700&display=swap");

    :root {
        --bg-base: #050505;
        --bg-panel: rgba(255, 255, 255, 0.035);
        --bg-panel-strong: rgba(255, 255, 255, 0.065);
        --text-main: #f5f5f7;
        --text-muted: #a1a1a6;
        --text-dim: #6f6f76;
        --border: rgba(255, 255, 255, 0.09);
        --accent: #ff5e00;
        --ue-cyan: #00f0ff;
        --deep-purple: #7000ff;
        --danger: #ff6666;
        --page-x: clamp(20px, 6vw, 72px);
        --header-height: 72px;
        --font-sans: "Inter", "Noto Sans SC", "PingFang SC", "Microsoft YaHei", -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", Arial, sans-serif;
        --font-display: "Noto Serif SC", "Inter", "Songti SC", "STSong", serif;
        --font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        --title-hero: clamp(2.85rem, 6.8vw, 5.5rem);
        --title-page: clamp(2.55rem, 5.8vw, 4.65rem);
        --title-article: clamp(2.1rem, 4.8vw, 3.85rem);
        --title-section: clamp(1.35rem, 2.4vw, 1.85rem);
        --title-card: clamp(1.06rem, 1.45vw, 1.24rem);
        --text-lead: clamp(1.08rem, 1.55vw, 1.28rem);
        --text-body: clamp(1rem, 1.2vw, 1.06rem);
        --tracking-kicker: 0.16em;
        color-scheme: dark;
    }

    :root[data-theme="light"] {
        --bg-base: #f4f1ea;
        --bg-panel: rgba(255, 255, 255, 0.68);
        --bg-panel-strong: rgba(255, 255, 255, 0.86);
        --text-main: #171717;
        --text-muted: #4d4d52;
        --text-dim: #77716c;
        --border: rgba(20, 20, 20, 0.12);
        --accent: #c84f12;
        --ue-cyan: #006b76;
        --deep-purple: #6b4ab0;
        --danger: #b43a34;
        color-scheme: light;
    }

    * {
        box-sizing: border-box;
    }

    html {
        min-height: 100%;
        background: var(--bg-base);
        scroll-behavior: smooth;
    }

    body {
        min-height: 100%;
        margin: 0;
        background:
            radial-gradient(circle at 18% 8%, rgba(0, 240, 255, 0.06), transparent 24rem),
            radial-gradient(circle at 92% 82%, rgba(255, 94, 0, 0.08), transparent 26rem),
            var(--bg-base);
        color: var(--text-main);
        font-family: var(--font-sans);
        font-weight: 400;
        line-height: 1.6;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
    }

    :root[data-theme="light"] body {
        background:
            radial-gradient(circle at 18% 8%, rgba(0, 107, 118, 0.08), transparent 24rem),
            radial-gradient(circle at 92% 82%, rgba(200, 79, 18, 0.08), transparent 26rem),
            var(--bg-base);
    }

    a {
        color: inherit;
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0 0 0 0);
        white-space: nowrap;
    }

    img,
    iframe,
    video {
        max-width: 100%;
    }

    img {
        display: block;
        height: auto;
    }

    .read-progress {
        position: fixed;
        top: 0;
        left: 0;
        z-index: 120;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, var(--accent), var(--ue-cyan));
        transform: scaleX(0);
        transform-origin: left center;
        will-change: transform;
    }

    .film-grain {
        position: fixed;
        inset: 0;
        z-index: 80;
        pointer-events: none;
        background-image: repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 3px);
        mix-blend-mode: soft-light;
        opacity: 0.018;
    }

    .ambient-background {
        position: fixed;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.014), transparent 34%),
            radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.032), transparent 42%);
    }

    .ambient-orb {
        position: absolute;
        border-radius: 999px;
        filter: blur(48px);
        mix-blend-mode: screen;
        opacity: 0.11;
    }

    .ambient-orb--ue {
        top: -12%;
        left: -10%;
        width: min(46vw, 620px);
        height: min(46vw, 620px);
        background: var(--ue-cyan);
    }

    .ambient-orb--film {
        right: -10%;
        bottom: -16%;
        width: min(42vw, 560px);
        height: min(42vw, 560px);
        background: var(--accent);
    }

    .ambient-orb--core {
        top: 24%;
        left: 36%;
        width: min(34vw, 460px);
        height: min(34vw, 460px);
        background: var(--deep-purple);
        opacity: 0.08;
    }

    .ambient-background--portfolio .ambient-orb--film,
    .ambient-background--article .ambient-orb--ue {
        opacity: 0.14;
    }

    .light-leak {
        position: absolute;
        width: 56vw;
        height: 18vh;
        background: linear-gradient(90deg, transparent, rgba(255, 94, 0, 0.16), transparent);
        filter: blur(18px);
        opacity: 0.24;
        transform: rotate(-8deg);
    }

    .light-leak--top {
        top: 4vh;
        right: -12vw;
    }

    .light-leak--bottom {
        left: -16vw;
        bottom: 8vh;
        opacity: 0.18;
        transform: rotate(10deg);
    }

    .glass-header {
        position: fixed;
        top: 0;
        left: 0;
        z-index: 100;
        width: 100%;
        min-height: var(--header-height);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 18px var(--page-x);
        background: rgba(5, 5, 5, 0.72);
        border-bottom: 1px solid rgba(255, 255, 255, 0.075);
        backdrop-filter: none;
        transition: background 220ms ease, border-color 220ms ease;
    }

    .glass-header.is-scrolled {
        background: rgba(5, 5, 5, 0.88);
        border-bottom-color: rgba(255, 255, 255, 0.1);
    }

    :root[data-theme="light"] .glass-header {
        background: rgba(244, 241, 234, 0.82);
        border-bottom-color: rgba(20, 20, 20, 0.1);
    }

    :root[data-theme="light"] .glass-header.is-scrolled {
        background: rgba(244, 241, 234, 0.94);
        border-bottom-color: rgba(20, 20, 20, 0.14);
    }

    .logo {
        color: var(--text-main);
        font-size: 1.05rem;
        font-weight: 760;
        letter-spacing: 0.04em;
        text-decoration: none;
        white-space: nowrap;
    }

    .logo .dot {
        color: var(--accent);
    }

    .nav-links {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: clamp(14px, 3vw, 34px);
    }

    .nav-links a {
        color: var(--text-muted);
        font-size: 0.85rem;
        font-weight: 520;
        text-decoration: none;
        transition: color 180ms ease;
    }

    .nav-links a:hover,
    .nav-links a.active {
        color: var(--text-main);
    }

    .theme-toggle {
        position: relative;
        display: inline-grid;
        place-items: center;
        width: 36px;
        height: 36px;
        border: 1px solid var(--border);
        border-radius: 50%;
        background: var(--bg-panel);
        color: var(--text-muted);
        cursor: pointer;
        font: inherit;
        padding: 0;
        transition: color 160ms ease, border-color 160ms ease, background 160ms ease;
    }

    .theme-icon {
        position: absolute;
        width: 17px;
        height: 17px;
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 1.9;
        transition: opacity 160ms ease, transform 160ms ease;
    }

    .theme-icon--moon {
        opacity: 0;
        transform: scale(0.82) rotate(-18deg);
    }

    :root[data-theme="light"] .theme-icon--sun {
        opacity: 0;
        transform: scale(0.82) rotate(18deg);
    }

    :root[data-theme="light"] .theme-icon--moon {
        opacity: 1;
        transform: scale(1) rotate(0deg);
    }

    .theme-toggle:hover {
        border-color: rgba(255, 94, 0, 0.42);
        color: var(--text-main);
        background: var(--bg-panel-strong);
    }

    .theme-tip {
        position: fixed;
        top: calc(var(--header-height) + 12px);
        right: var(--page-x);
        z-index: 115;
        display: flex;
        align-items: center;
        gap: 12px;
        max-width: min(320px, calc(100vw - 40px));
        padding: 10px 12px 10px 14px;
        border: 1px solid rgba(255, 94, 0, 0.28);
        border-radius: 8px;
        background: rgba(10, 10, 11, 0.88);
        color: #f5f5f7;
        box-shadow: 0 18px 48px rgba(0, 0, 0, 0.22);
        font-size: 0.86rem;
        line-height: 1.5;
        backdrop-filter: blur(12px);
    }

    .theme-tip[hidden] {
        display: none;
    }

    .theme-tip button {
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        width: 24px;
        height: 24px;
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.06);
        color: currentColor;
        cursor: pointer;
        font: inherit;
        line-height: 1;
        padding: 0;
    }

    .theme-tip button:hover {
        border-color: rgba(255, 94, 0, 0.58);
    }

    .page-shell {
        position: relative;
        z-index: 10;
        width: min(100%, 1440px);
        margin: 0 auto;
        padding: calc(var(--header-height) + 48px) var(--page-x) 96px;
    }

    html.js [data-reveal] {
        opacity: 0;
        transform: translateY(14px);
        transition: opacity 360ms ease, transform 360ms ease;
    }

    html.js [data-reveal].is-visible {
        opacity: 1;
        transform: translateY(0);
    }

    .eyebrow {
        display: block;
        color: var(--accent);
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 760;
        letter-spacing: var(--tracking-kicker);
        text-transform: uppercase;
    }

    .section-heading {
        display: flex;
        align-items: center;
        gap: 18px;
        margin: 0 0 32px;
    }

    .section-heading h2 {
        margin: 0;
        color: var(--text-main);
        font-family: var(--font-display);
        font-size: var(--title-section);
        font-weight: 650;
        line-height: 1.18;
        letter-spacing: 0;
    }

    :root[data-theme="light"] .section-heading h2,
    :root[data-theme="light"] .profile-col h1,
    :root[data-theme="light"] .lang-content strong,
    :root[data-theme="light"] .contact-box a,
    :root[data-theme="light"] .archive-hero h1,
    :root[data-theme="light"] .portfolio-hero h1,
    :root[data-theme="light"] .article-hero--no-cover .article-heading h1,
    :root[data-theme="light"] .case-section h2,
    :root[data-theme="light"] .case-section h3,
    :root[data-theme="light"] .card-info h3,
    :root[data-theme="light"] .archive-item strong,
    :root[data-theme="light"] .reference-item strong,
    :root[data-theme="light"] .prose strong,
    :root[data-theme="light"] .logo {
        color: var(--text-main);
    }

    :root[data-theme="light"] .prose,
    :root[data-theme="light"] .toc,
    :root[data-theme="light"] .lang-content p,
    :root[data-theme="light"] .card-info p,
    :root[data-theme="light"] .portfolio-hero p,
    :root[data-theme="light"] .article-hero--no-cover .article-heading p,
    :root[data-theme="light"] .archive-item small,
    :root[data-theme="light"] .reference-item small,
    :root[data-theme="light"] .case-section p {
        color: var(--text-muted);
    }

    :root[data-theme="light"] .cinematic-frame,
    :root[data-theme="light"] .card-image,
    :root[data-theme="light"] .article-cover,
    :root[data-theme="light"] .tech-grid article,
    :root[data-theme="light"] .lesson-list article {
        background: rgba(255, 255, 255, 0.72);
        border-color: var(--border);
        box-shadow: 0 18px 48px rgba(32, 28, 22, 0.08);
    }

    :root[data-theme="light"] .article-hero:not(.article-hero--no-cover) .article-heading h1,
    :root[data-theme="light"] .case-hero__overlay h1,
    :root[data-theme="light"] .case-detail-hero h1 {
        color: #fff;
    }

    :root[data-theme="light"] .article-hero:not(.article-hero--no-cover) .article-heading p,
    :root[data-theme="light"] .case-hero p,
    :root[data-theme="light"] .case-detail-hero p,
    :root[data-theme="light"] .case-meta span {
        color: #d4d4d8;
    }

    :root[data-theme="light"] .ambient-background {
        opacity: 0.58;
        mix-blend-mode: multiply;
    }

    :root[data-theme="light"] .film-grain {
        opacity: 0.012;
        mix-blend-mode: multiply;
    }

    .section-heading::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
    }

    .site-footer {
        position: relative;
        z-index: 10;
        padding: 48px var(--page-x);
        border-top: 1px solid var(--border);
        color: var(--text-dim);
        font-size: 0.82rem;
        text-align: center;
    }

    @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
            scroll-behavior: auto !important;
            animation-duration: 0.001ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.001ms !important;
        }

        body {
            background: var(--bg-base);
        }
    }

    @media (max-width: 760px) {
        :root {
            --header-height: 96px;
        }

        .ambient-orb {
            animation: none;
            filter: blur(40px);
            opacity: 0.1;
        }

        .glass-header {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            grid-template-areas:
                "logo toggle"
                "nav nav";
            align-items: center;
            gap: 10px;
            padding-top: 14px;
            padding-bottom: 14px;
        }

        .logo {
            grid-area: logo;
        }

        .theme-toggle {
            grid-area: toggle;
            justify-self: end;
        }

        .nav-links {
            grid-area: nav;
            width: 100%;
            min-width: 0;
            justify-content: flex-start;
            gap: 18px;
            overflow-x: auto;
            padding-bottom: 2px;
        }

        .nav-links a {
            white-space: nowrap;
        }

        .page-shell {
            padding-top: calc(var(--header-height) + 38px);
            padding-bottom: 72px;
        }

        .theme-tip {
            top: auto;
            right: 20px;
            bottom: 20px;
            left: 20px;
            max-width: none;
            justify-content: space-between;
        }
    }
</style>
